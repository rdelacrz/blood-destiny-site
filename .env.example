# =====================================================================
# Updates feed — VITE_UPDATES_API_URL
# The Updates timeline fetches its devlog entries as JSON from this endpoint.
# It is build-time inlined (VITE_*), so changing it needs a rebuild/redeploy.
#
# This repo ships per-mode defaults so it works out of the box:
#   .env.development → http://localhost:8787/updates  (the local shim)
#   .env.production  → /api/updates                   (same-origin function)
# Override locally (secrets / your own URL) in .env.local or .env.*.local,
# which are gitignored.
#
# Endpoint contract (see src/api/updates.ts): a bare array, or an
# { "items": [...] } / { "ret": [...] } envelope, of rows shaped like — field
# names LOWERCASE because Postgres folds unquoted aliases (post_id → "postid"):
#   { postid, title, date (ISO), description (HTML), coverimage?, updateby? }
#
# Production route: api/updates.js (a Vercel serverless function) runs the
# Postgres query and serves this shape same-origin at /api/updates. It needs
# POSTGRES_URL configured on the Vercel project — a SERVER-SIDE secret, NEVER a
# VITE_ var and never in the client bundle. Pull it locally with
# `vercel env pull .env.local` if you want to run the real function via
# `vercel dev` (otherwise use `npm run updates:proxy`).
#
# Cross-origin instead of same-origin? The endpoint must send CORS headers
# (Access-Control-Allow-Origin) for http://localhost:5173 and your prod origin.
#
# Leave empty to fall back to the bundled seed entries (src/data/updates.ts).
# =====================================================================
VITE_UPDATES_API_URL=

# Optional base URL prepended to relative cover_image paths (absolute URLs and
# root-relative paths are used as-is). e.g. https://blood-destiny.imgix.net
VITE_UPDATES_IMAGE_BASE=
